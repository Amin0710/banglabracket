{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm ci && npm run build:shared && npm run build -w @banglabracket/api"
  },
  "deploy": {
    "startCommand": "npm run start -w @banglabracket/api",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
