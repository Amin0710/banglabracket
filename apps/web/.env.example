# Web app environment (Vite). Only needed in PRODUCTION.
#
# In local dev you can leave this empty — vite.config.ts proxies /api and /auth
# to http://localhost:4000 so the session cookie stays same-origin.
#
# In production set this to your API origin, e.g.:
# VITE_API_URL=https://api.banglabracket.com
VITE_API_URL=
