# ============================================================
#  BanglaBracket API — environment variables
#  Copy to `.env` for local dev. On Railway, set these in the
#  service "Variables" tab (do NOT commit your real .env).
# ============================================================

NODE_ENV=development
PORT=4000

# Public URLs. In dev the web app proxies to the API so these can stay as-is.
# In production:  API_URL=https://api.banglabracket.com   WEB_URL=https://banglabracket.com
API_URL=http://localhost:4000
WEB_URL=http://localhost:5173
# The app is served under this path (so banglabracket.com/wc2026/app is the game,
# leaving the root free for marketing and future tournaments like /euro2028/app).
WEB_APP_PATH=/wc2026/app

# ---- Database (MongoDB Atlas) ----
# Atlas → Cluster → "Connect" → "Drivers" → copy the SRV string.
# Replace <password> and add the db name (banglabracket). Compass uses the same string.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/banglabracket?retryWrites=true&w=majority

# ---- Secrets (generate each with:  openssl rand -hex 32) ----
JWT_SECRET=replace_with_64_hex_chars
ENCRYPTION_KEY=replace_with_64_hex_chars

# ---- Session cookie ----
COOKIE_NAME=bb_session
# true in production (HTTPS only)
COOKIE_SECURE=false
# IMPORTANT for production: host web + api on the SAME registrable domain and set this,
# e.g. web=banglabracket.com, api=api.banglabracket.com  ->  COOKIE_DOMAIN=.banglabracket.com
# That keeps auth a first-party cookie (SameSite=Lax) and avoids third-party-cookie blocking.
# Leave blank for local dev.
COOKIE_DOMAIN=
SESSION_TTL_DAYS=60

# ---- Admin access ----
# Comma-separated emails. Anyone signing in with one of these becomes an admin.
ADMIN_EMAILS=you@example.com

# ---- Google OAuth ----
# console.cloud.google.com → APIs & Services → Credentials → OAuth client (Web).
# Authorized redirect URI:  {API_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Facebook OAuth (kept off until your app is approved) ----
# developers.facebook.com → your app → Facebook Login → Settings.
# Valid OAuth redirect URI:  {API_URL}/auth/facebook/callback
# Flip FACEBOOK_ENABLED=true only once approved; the button stays hidden on the
# frontend until you also set FACEBOOK_VISIBLE=true in apps/web/src/pages/SignIn.tsx.
FACEBOOK_ENABLED=false
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ---- Email login codes (Resend) ----
# resend.com → API Keys. Verify your sending domain (DNS) first — that can take a while,
# so do it early. If RESEND_API_KEY is blank, login codes print to the API console (dev).
RESEND_API_KEY=
MAIL_FROM=BanglaBracket <login@banglabracket.com>
EMAIL_CODE_TTL_MIN=10

# ---- Tournament ----
TOURNAMENT_KEY=wc2026
